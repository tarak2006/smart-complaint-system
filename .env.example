# --- SERVER CONFIG ---
PORT=5000

# --- AZURE STORAGE ---
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# --- AZURE SQL ---
SQL_SERVER=astracare-db.database.windows.net
SQL_DATABASE=AstraCareDB
SQL_USER=admin
SQL_PASSWORD=...

# --- AZURE FUNCTIONS ---
AZURE_FUNCTION_URL=https://astracare-funcs.azurewebsites.net/api

# --- AZURE KEY VAULT ---
AZURE_KEYVAULT_NAME=astracare-kv

# --- MONITORING ---
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
